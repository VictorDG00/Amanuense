DEEPSEEK_API_KEY=sk-...
AMANUENSE_MODEL=deepseek-chat
AMANUENSE_MAX_TOKENS=8192
AMANUENSE_CORPUS_DIR=corpus
AMANUENSE_OUTPUT_DIR=output
AMANUENSE_INTERMEDIATE_DIR=intermediate

# Base de legislação estruturada (PostgreSQL 14+ com btree_gist).
# Sem esta variável o pipeline roda em modo legado (somente JSON).
# Docker: o serviço `postgres` do docker-compose já provê o banco.
# Dev local sem docker:
#   docker run -d --name legislacao -p 5433:5432 \
#     -e POSTGRES_DB=legislacao -e POSTGRES_USER=amanuense \
#     -e POSTGRES_PASSWORD=amanuense postgres:16-alpine
#   LEGISLACAO_DATABASE_URL=postgresql://amanuense:amanuense@localhost:5433/legislacao
# Depois: `amanuense initdb` (ou `amanuense initdb --with-demo` para o seed da LGPD).
LEGISLACAO_DATABASE_URL=
